---
import Main from '../../layouts/Main.astro';
import BlogPostPreview from '../../components/blog/BlogPostPreview.astro';

interface Frontmatter {
   title: string;
   description: string;
   author: string;
   publishDate: string;
   updatedDate: string;
   layout: string;
}

const pageDetails = {
   title: 'Blog',
   description: 'A personal website of mine.',
   overrideTitle: false,
};

let allPosts = Object.values(import.meta.glob<Frontmatter>('./post/*.md', { eager: true }));
allPosts = allPosts.sort(
   (a, b) => new Date(b.publishDate).valueOf() - new Date(a.publishDate).valueOf(),
);
---

<Main pageDetails={pageDetails}>
   <section class="wrapper readable">
      {
         allPosts.map((p) => (
            <>
               <br />
               <div class="panel-border">
                  <BlogPostPreview post={p} />
               </div>
            </>
         ))
      }
   </section>
</Main>
