---
export interface Props {
    filePath: string;
}
const { filePath } = Astro.props as Props;
---
<img class="avatar" loading="lazy" alt={`${filePath.split('.')[0]}`} src={`/assets/img/avatar/${filePath}`}>

<style lang="scss">
    .avatar {
        width: 100%;
        height: auto;
        box-shadow: -0.125rem 0.125rem 0.5rem black;
        border-radius: 50%;
    }
</style>
