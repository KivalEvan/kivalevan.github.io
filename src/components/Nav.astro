---
export interface Props {
    isHome?: boolean;
    currPage?: string;
}
const { isHome, currPage } = Astro.props as Props;
const pages = [
    {name: 'Home', link: '/'},
    {name: 'Project', link: '/project'},
    {name: 'Commission', link: '/commission'},
    {name: 'Guide', link: '/guide'}];
// smort
if (isHome) {
    pages.shift();
}
pages.forEach(page => {
    if (page.name.toLowerCase() === currPage?.toLowerCase()) {
        page.active = true;
    }
})
---
<div class="container">
    <nav role="navigation">
        {pages.map((page) => (
            <a href={page.link} class={page.active ? "active" : ""}><span>{page.name}</span></a>
        ))}
    </nav>
</div>

<style lang="scss">
    $width-phone: 750px;
    $width-widescreen: 1600px;

    .container {
        display: flex;
        justify-content: center;
    }
    nav {
        padding-top: 0.5em;
        padding-bottom: 0.5em;
        white-space :nowrap;
        overflow: auto;
    }
    a {
        font-size: 1.75rem;
        padding: 0.0625em 0.125em;
        margin-left: 0.75em;
        margin-right: 0.75em;
        border-bottom: 0.0625em solid #cccccc00;
        text-shadow: 0 0 0.25em black, 0 0 0.125em black;
        text-decoration: none;
        text-transform: uppercase;
        font-weight: bold;
        color: white;
        transition: padding 0.2s ease, margin 0.2s ease, border 0.1875s ease;
        span {
            display: inline-block;
            transition: transform 0.2s ease;
        }
        &:visited {
            color: white;
        }
        &:hover, &.active {
            padding: 0.0625em 0.75em;
            border-bottom-color: #ff0000ff;
            margin-left: 0.125em;
            margin-right: 0.125em;
            color: white;
            span {
                transform: scale(1.1, 1.1);
            }
        }
        @media (max-width: $width-phone) {
            font-size: 2rem;
        }
    }
</style>
